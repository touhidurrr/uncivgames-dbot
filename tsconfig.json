{
  "include": ["src", "scripts"],
  "compilerOptions": {
    "types": ["bun", "@cloudflare/workers-types"],

    "noEmit": true,
    "skipLibCheck": true,

    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],

    "paths": {
      "@src/*": ["./src/*"],

      "@modules/*": ["./src/modules/*"],
      "@interactions/*": ["./src/Interactions/*"],

      "@lib": ["./src/lib.ts"],
      "@models": ["./src/models.ts"],
      "@secrets": ["./src/secrets.ts"],
      "@constants": ["./src/constants.ts"],

      "@prismaGenerated/*": ["./prisma/generated/*"]
    }
  }
}
